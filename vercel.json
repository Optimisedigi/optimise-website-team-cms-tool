    "src/app/(frontend)/api/[...slug]/route.ts": {
      "maxDuration": 60
    },
    "src/app/(frontend)/api/proposals/[id]/run-audits/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/migrate/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/schema-migrate/route.ts": {
      "maxDuration": 60
    },
    "src/app/(frontend)/api/google-ads-snapshots/cron/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/gsc/indexing-audit/route.ts": {
      "maxDuration": 120
    },
    "src/app/(frontend)/api/gsc/indexing-audit/[id]/inspect/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/gsc/indexing-helper/run/route.ts": {
      "maxDuration": 120
    },
    "src/app/(frontend)/api/gsc/cron/route.ts": {
      "maxDuration": 120
    },
    "src/app/(frontend)/api/dashboard/prewarm/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/dashboard/prewarm/run/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/scheduled-tasks/tick/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/contract-reminders/tick/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/invoice-statements/sweep/route.ts": {
      "maxDuration": 120
    },
    "src/app/(frontend)/api/contracts/trash-sweep/route.ts": {
      "maxDuration": 120
    },
    "src/app/(frontend)/api/match-type-violations/cron/route.ts": {
      "maxDuration": 180
    },
    "src/app/(frontend)/api/goal-agents/cron/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/goal-agents/watchdog/route.ts": {
      "maxDuration": 180
    }
