{
  "name": "content-cms",
  "version": "1.0.0",
  "description": "Multi-client content management system",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 3004",
    "start": "next start -p 3001",
    "generate:types": "payload generate:types",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "optimate:evaluate": "node --env-file=.env --import tsx scripts/optimate-google-ads-eval.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@neondatabase/serverless": "^1.0.2",
    "@payloadcms/db-sqlite": "^3.17.0",
