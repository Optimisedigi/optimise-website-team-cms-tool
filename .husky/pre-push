  echo "⚠️  Schema-related files changed:"
  echo "$COLLECTION_CHANGES"
  echo ""
  echo "👉 After Vercel deploys, run the migration against production:"
  echo "   curl -X POST https://cms.optimisedigital.online/api/migrate -H 'x-api-key: \$AUDIT_API_KEY'"
  echo ""
fi
