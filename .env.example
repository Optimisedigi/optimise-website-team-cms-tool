DATABASE_URL=file:./content.db
DATABASE_AUTH_TOKEN=
PAYLOAD_SECRET=YOUR_SECRET_HERE
AUDIT_API_KEY=YOUR_AUDIT_API_KEY_HERE
GROWTH_TOOLS_URL=https://your-growth-tools.up.railway.app
INTERNAL_API_KEY=SHARED_SECRET_MATCHING_GROWTH_TOOLS
SCRAPLING_SERVICE_URL=https://your-scrapling-service.up.railway.app
SCRAPLING_SERVICE_KEY=SHARED_SECRET_FOR_SCRAPLING

# Optimate agents (Phase 0)
# 32 hex bytes (64 chars) used to encrypt OAuth tokens at rest in the
# agent-credentials collection. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRED_ENCRYPTION_KEY=

# Optimate-Google-Ads is configured Kimi-primary, MiniMax-fallback. Both
# keys required for that chain. Anthropic is supported but currently
# deprioritised; set ANTHROPIC_API_KEY only if you also want Anthropic
# models in the agent fleet.
KIMI_API_KEY=
MINIMAX_API_KEY=

# Optional. The framework supports Anthropic (with OAuth via /agent-auth)
# but no agent currently defaults to it. Leave unset until needed.
ANTHROPIC_API_KEY=
