{
  "crons": [
    {
      "path": "/api/gsc/cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/dashboard/prewarm",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/scheduled-tasks/tick",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/contract-reminders/tick",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/invoice-statements/sweep",
      "schedule": "0 22 1 * *"
    },
    {
      "path": "/api/contracts/trash-sweep",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/match-type-violations/cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/google-ads-snapshots/cron",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/goal-agents/cron",
      "schedule": "0 */1 * * *"
    },
    {
      "path": "/api/goal-agents/watchdog",
      "schedule": "0 5 * * *"
    }
  ],
  "functions": {
    "src/app/(payload)/admin/[[...segments]]/page.tsx": {
