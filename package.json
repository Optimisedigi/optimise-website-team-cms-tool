    "@types/react-dom": "^19.0.0",
    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "bcryptjs": "^3.0.3",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.8",
