{
  "crons": [
    {
      "path": "/api/gsc/cron",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "src/app/(payload)/admin/[[...segments]]/page.tsx": {
      "maxDuration": 30
    },
    "src/app/(payload)/admin/[[...segments]]/not-found.tsx": {
      "maxDuration": 30
    },
    "src/app/(frontend)/api/[...slug]/route.ts": {
      "maxDuration": 60
    },
    "src/app/(frontend)/api/proposals/[id]/run-audits/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/migrate/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/schema-migrate/route.ts": {
      "maxDuration": 60
    },
    "src/app/(frontend)/api/gsc/indexing-audit/route.ts": {
      "maxDuration": 120
    },
    "src/app/(frontend)/api/gsc/indexing-audit/[id]/inspect/route.ts": {
      "maxDuration": 300
    },
    "src/app/(frontend)/api/gsc/indexing-helper/run/route.ts": {
      "maxDuration": 120
    },
    "src/app/(frontend)/api/gsc/cron/route.ts": {
      "maxDuration": 120
    }
  }
}
