DATABASE_URL=file:./content.db
DATABASE_AUTH_TOKEN=
PAYLOAD_SECRET=YOUR_SECRET_HERE
AUDIT_API_KEY=YOUR_AUDIT_API_KEY_HERE
GROWTH_TOOLS_URL=https://your-growth-tools.up.railway.app
INTERNAL_API_KEY=SHARED_SECRET_MATCHING_GROWTH_TOOLS
SCRAPLING_SERVICE_URL=https://your-scrapling-service.up.railway.app
SCRAPLING_SERVICE_KEY=SHARED_SECRET_FOR_SCRAPLING

# Optimate agents (Phase 0)
# 32 hex bytes (64 chars) used to encrypt OAuth tokens at rest in the
# agent-credentials collection. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRED_ENCRYPTION_KEY=

# Optimate-Google-Ads chat defaults to Claude Sonnet 4.6 via OAuth (Claude
# Code client impersonation, configured at /agent-auth). When OAuth isn't
# connected the chain falls through to Kimi K2.6, then MiniMax M2.7 — both
# keys required for the fallback chain to actually work end-to-end.
#
# KIMI_API_KEY is the canonical name; MOONSHOT_API_KEY is accepted as an
# alias so external code samples drop in unchanged.
KIMI_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=

# Optional API-key path for Anthropic. Only used when the user explicitly
# selects an Anthropic model AND no OAuth credential is connected. Leave
# unset to force the chat off Anthropic when OAuth isn't set up.
ANTHROPIC_API_KEY=
