    "@payloadcms/richtext-lexical": "^3.17.0",
    "@payloadcms/storage-vercel-blob": "^3.73.0",
    "@payloadcms/ui": "^3.17.0",
    "@react-pdf/renderer": "^4.3.2",
    "@sendgrid/mail": "^8.1.6",
    "@vercel/blob": "^2.2.0",
    "cron-parser": "^5.5.0",
    "docx": "^9.6.0",
    "googleapis": "^171.4.0",
    "graphql": "^16.8.1",
    "gray-matter": "^4.0.3",
    "next": "^16.1.6",
    "payload": "^3.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
